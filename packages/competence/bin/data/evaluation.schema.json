{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ti-engine.dev/schemas/competence/evaluation.json",
  "title": "Competency Evaluation",
  "description": "A single employee competency evaluation record.",
  "type": "object",
  "required": [
    "evaluationID",
    "employeeID",
    "cycleID",
    "cycleDate",
    "status",
    "grades"
  ],
  "additionalProperties": false,
  "properties": {
    "evaluationID": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the evaluation"
    },
    "employeeID": {
      "type": "string",
      "description": "ID of the employee being evaluated"
    },
    "managerID": {
      "type": "string",
      "description": "ID of the manager who reviews the evaluation"
    },
    "cycleID": {
      "type": "string",
      "description": "Identifier of the evaluation cycle (e.g., 2025.H1)"
    },
    "cycleDate": {
      "type": "string",
      "format": "date",
      "description": "Official date of the cycle closing"
    },
    "interviewDate": {
      "type": [
        "string",
        "null"
      ],
      "format": "date",
      "description": "Date when the evaluation interview took place"
    },
    "status": {
      "type": "string",
      "enum": [
        "Open",
        "In Review",
        "Ready",
        "Closed",
        "Deleted"
      ],
      "description": "Current status of the evaluation (e.g., Open, Closed)"
    },
    "grades": {
      "type": "object",
      "description": "Collection of grades keyed by competency ID",
      "patternProperties": {
        "^[EIC][1-3]-\\d+$": {
          "$ref": "#/$defs/gradeEntry"
        }
      },
      "additionalProperties": false
    },
    "comment": {
      "type": "string",
      "description": "Comment submitted by the employee"
    },
    "feedback": {
      "type": "object",
      "description": "Feedback attached to the evaluation",
      "additionalProperties": false,
      "properties": {
        "managerComment": {
          "type": "string",
          "description": "Comment submitted by the manager"
        },
        "teamComments": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Comments submitted by the team members"
        }
      }
    },
    "workflow": {
      "type": "object",
      "description": "System workflow state for the evaluation",
      "additionalProperties": false,
      "properties": {
        "currentStep": {
          "type": "string",
          "enum": [
            "1",
            "2",
            "3",
            "4",
            "5",
            "6",
            "7",
            "8"
          ],
          "description": "Current step in the workflow"
        },
        "selfEvaluationCompleted": {
          "type": "boolean",
          "description": "Indicates if self-evaluation has been completed"
        },
        "selfEvaluationDeadline": {
          "type": "string",
          "format": "date",
          "description": "Deadline for self-evaluation submission"
        },
        "teamEvaluationCompleted": {
          "type": "boolean",
          "description": "Indicates if team-evaluation has been completed"
        },
        "teamEvaluationDeadline": {
          "type": "string",
          "format": "date",
          "description": "Deadline for team-evaluation submission"
        },
        "managerEvaluationCompleted": {
          "type": "boolean",
          "description": "Indicates if manager-evaluation has been completed"
        },
        "managerEvaluationDeadline": {
          "type": "string",
          "format": "date",
          "description": "Deadline for manager-evaluation submission"
        },
        "teamEvaluationsSubmitted": {
          "type": "integer",
          "description": "Number of team evaluations submitted"
        },
        "team": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of employee IDs of the team members to provide team-evaluation"
        }
      }
    }
  },
  "$defs": {
    "gradeEntry": {
      "type": "object",
      "description": "Grades assigned by different roles",
      "additionalProperties": false,
      "properties": {
        "employee": {
          "$ref": "#/$defs/gradeValue"
        },
        "manager": {
          "$ref": "#/$defs/gradeValue"
        },
        "team": {
          "type": "object",
          "description": "Team evaluation grades",
          "additionalProperties": false,
          "properties": {
            "cumulative": {
              "$ref": "#/$defs/gradeValue"
            },
            "individual": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/gradeValue"
              }
            }
          }
        }
      }
    },
    "gradeValue": {
      "type": "string",
      "enum": [
        "U",
        "R",
        "S",
        ""
      ],
      "description": "Competency level: U (Under-Performance), R (Regular/Expected Performance), S (Superior Performance)"
    }
  }
}