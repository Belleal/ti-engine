{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "performanceAppraisals": {
      "type": "object",
      "properties": {
        "minTeamEvaluationMembers": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Minimum number of team members required for team evaluations"
        },
        "numberOfNextPeriodGoals": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "description": "Number of goals to set for the next evaluation period"
        }
      },
      "required": [
        "minTeamEvaluationMembers",
        "numberOfNextPeriodGoals"
      ]
    }
  },
  "required": [
    "performanceAppraisals"
  ]
}